{
  "expo": {
    "name": "dukanak world",
    "slug": "doccank",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doccank",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "icon": "./assets/images/icon.png",
      "permissions": ["ACCESS_FINE_LOCATION", "NOTIFICATIONS"],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.abdullah.lahham125.doccank"
    },
    "ios": {
      "bundleIdentifier": "com.abdullah.lahham125.doccank",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to deliver orders faster",
        "UIBackgroundModes": ["remote-notification"],
        "FirebaseAppDelegateProxyEnabled": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useModularHeaders": true,
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "FirebaseCoreInternal", "modular_headers": true },
              { "name": "FirebaseCore", "modular_headers": true },
              { "name": "FirebaseInstallations", "modular_headers": true },
              { "name": "FirebaseMessaging", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ce1b8bd-619e-455a-a7db-7a015652c113"
      }
    }
  }
}
